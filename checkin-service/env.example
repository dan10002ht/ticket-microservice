# ============================================
# Checkin Service — environment variables
# ============================================

# gRPC port (checkin-service listens here)
GRPC_PORT=50059

# Prometheus metrics port
METRICS_PORT=2112

# PostgreSQL (shared main DB)
DB_HOST=localhost
DB_PORT=50433
DB_NAME=booking_system
DB_USER=booking_user
DB_PASSWORD=booking_pass
DB_SSL_MODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=5m

# Downstream gRPC: ticket-service
TICKET_SERVICE_HOST=ticket-service
TICKET_SERVICE_PORT=50054

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
